#!/usr/bin/env bash
#
# Wrapper that calls your LLM to write output/edition.json from PROMPT.md.
#
# COPY this file to scripts/agent-invoke.sh, then edit. The renamed file is
# gitignored on purpose so each operator can wire it to their own LLM /
# credentials without leaking into the repo.
#
# CONTRACT
# ========
# Input:
#   - PROMPT.md at the project root (the curation prompt)
#   - /tmp/preflight/news.json   (pre-fetched, pre-shortlisted news candidates)
#   - /tmp/preflight/arxiv.json  (pre-fetched, pre-shortlisted paper candidates)
#   - /tmp/preflight/instructions.txt (a tiny pointer note)
#
# Output:
#   - output/edition.json (the LLM writes this)
#
# Exit code:
#   - 0 if the LLM completed (run_daily.sh will then validate the file)
#   - nonzero if the LLM CLI itself failed
#
# Below are example invocations for several agents. Keep one, delete the
# rest, and adjust the model name.

set -euo pipefail
REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$REPO_ROOT"
PROMPT_FILE="$REPO_ROOT/PROMPT.md"


# ---------------------------------------------------------------------------
# Example 1: Claude Code (uses ANTHROPIC_API_KEY from env or keychain)
# ---------------------------------------------------------------------------
# claude -p "$(cat "$PROMPT_FILE")" \
#   --permission-mode acceptEdits \
#   --max-turns 30


# ---------------------------------------------------------------------------
# Example 2: openclaw (cheap-LLM open-source agent — adjust to your install)
# ---------------------------------------------------------------------------
# Most openclaw-style agents take a prompt and an allowed-tools list.
# openclaw \
#   --prompt-file "$PROMPT_FILE" \
#   --working-dir "$REPO_ROOT" \
#   --model gpt-3.5-turbo \
#   --allow file_read,file_write \
#   --max-iterations 20


# ---------------------------------------------------------------------------
# Example 3: aider (works with any LLM provider via LiteLLM)
# ---------------------------------------------------------------------------
