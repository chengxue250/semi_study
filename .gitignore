# Local notification config (contains your secret ntfy topic).
# Copy notify.yaml.example to notify.yaml and edit.
notify.yaml

# Run logs from launchd / cron.
output/run.log
output/launchd.out.log
output/launchd.err.log

# Generated podcast audio — large, and the podcast platforms host it for you.
# The small .txt scripts and .notes.md show notes ARE kept (not ignored).
output/podcast/*.m4a
output/podcast/*.aiff
output/podcast/*.wav

# Local voice-clone model environment (multi-GB; recreate via the venv steps
# in references/voice-clone-guide.md). Never committed.
.venv-tts/

# Your recorded reference voice — personal data; never commit it.
assets/voice/*.wav
assets/voice/*.m4a
assets/voice/*.mp3
assets/voice/*.aiff

# Editor / OS noise.
.DS_Store
*.swp
.idea/
.vscode/
__pycache__/

# Agent-CLI machine-local settings (Claude Code, etc.).
.claude/
scripts/agent-invoke.sh
output/edition.json.previous
